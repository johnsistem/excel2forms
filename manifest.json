{
  "manifest_version": 3,
  "name": "Asistente de Accesibilidad Visual",
  "version": "1.0.0",
  "description": "Herramienta de accesibilidad para digitalizar documentos impresos.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Asistente de Accesibilidad"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://serviciosenlinea.mined.gob.ni/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*", "http://localhost:8000/*", "http://0.0.0.0:8000/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://serviciosenlinea.mined.gob.ni/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "file:///*"
  ]
}
